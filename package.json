{
  "name": "fb-ai-agent",
  "version": "1.0.0",
  "type": "module",
  "description": "Facebook AI Agent — GHL Expert Edition with Russell Brunson Frameworks",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
